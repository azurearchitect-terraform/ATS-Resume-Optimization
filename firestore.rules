rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - userId: string (required) - The unique identifier for the user.
    //   - encryptedApiKey: string (required) - The user's API key, encrypted by the backend.
    //   - masterResume: string (required) - The user's master resume data.
    //   - updatedAt: timestamp (optional) - When the profile was last updated.
    //
    // Collection: resumeVersions
    // Document ID: {versionId}
    // Fields:
    //   - userId: string (required) - The unique identifier for the user.
    //   - timestamp: timestamp (required) - The timestamp when the version was saved.
    //   - name: string (required) - The name of the saved version.
    //   - data: map (required) - The resume data for this version.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the resource (for user-owned documents)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if user is an admin
    function isAdmin() {
      return isAuthenticated() && 
             ( (request.auth.token.email == "hackerharnish@gmail.com" && request.auth.token.email_verified == true) ||
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') );
    }

    // Validate required fields exist
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    // Validate that the document contains only the allowed fields
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validator for UserProfile
    function isValidUserProfile(data, userId) {
      return hasOnlyAllowedFields(['userId', 'encryptedApiKey', 'masterResume', 'customPrompt', 'driveAccessToken', 'settings', 'updatedAt']) &&
             data.userId is string && data.userId == userId &&
             (!('encryptedApiKey' in data) || (data.encryptedApiKey is string && data.encryptedApiKey.size() < 2000)) &&
             (!('masterResume' in data) || (data.masterResume is string && data.masterResume.size() < 500000)) &&
             (!('customPrompt' in data) || (data.customPrompt is string && data.customPrompt.size() < 5000)) &&
             (!('driveAccessToken' in data) || (data.driveAccessToken is string && data.driveAccessToken.size() < 2000)) &&
             (!('settings' in data) || data.settings is map) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // Domain Validator for ResumeVersion
    function isValidResumeVersion(data, userId) {
      return hasOnlyAllowedFields(['userId', 'timestamp', 'name', 'data']) &&
             data.userId is string && data.userId == userId &&
             data.timestamp is timestamp &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.data is map;
    }

    // Domain Validator for TokenUsage
    function isValidTokenUsage(data, userId) {
      return hasOnlyAllowedFields(['userId', 'month', 'gemini', 'openai', 'updatedAt']) &&
             data.userId is string && data.userId == userId &&
             data.month is string && data.month.matches('^\\d{4}-\\d{2}$') &&
             (!('gemini' in data) || (data.gemini is map && data.gemini.input is number && data.gemini.output is number)) &&
             (!('openai' in data) || (data.openai is map && data.openai.input is number && data.openai.output is number)) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can only read their own profile
      allow read: if isOwner(userId);
      
      // Users can create their own profile
      allow create: if isOwner(userId) && 
                    isValidUserProfile(request.resource.data, userId);
                    
      // Users can update their own profile
      allow update: if isOwner(userId) && 
                    isValidUserProfile(request.resource.data, userId);
                    
      // Users can delete their own profile
      allow delete: if isOwner(userId);

      match /resumeVersions/{versionId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && 
                              isValidResumeVersion(request.resource.data, userId);
      }

      match /tokenUsage/{monthId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && 
                              isValidTokenUsage(request.resource.data, userId);
      }
    }

    match /analytics/{logId} {
      // Only admins should be able to read analytics
      allow read: if isAdmin();
      // Allow authenticated users to log their own usage
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
